DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,https://your-domain.example.com
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_PROXY_SSL_HEADER=False

