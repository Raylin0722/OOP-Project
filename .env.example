# ============================================================
# Django Basic Settings
# ============================================================

# Django secret key.
# Please replace this value with a long random string before running the system.
DJANGO_SECRET_KEY=Your-Secret-key

# Debug mode.
# For normal local execution, keep this as False.
DJANGO_DEBUG=False

# Redis connection URL used by Django Channels.
REDIS_URL=redis://redis:6379/0

# Channel layer backend.
# This project uses Redis as the WebSocket channel layer.
CHANNEL_LAYER_BACKEND=redis


# ============================================================
# Host / CORS / CSRF Settings
# ============================================================

# Allowed hosts for Django backend.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Allowed origins for frontend requests.
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1,http://localhost,http://127.0.0.1:8088,http://localhost:8088

# Trusted origins for CSRF protection.
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1,http://localhost,http://127.0.0.1:8088,http://localhost:8088

# HTTPS-related settings.
# In local Docker execution, these values can remain False.
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_PROXY_SSL_HEADER=False


# ============================================================
# Email Settings
# ============================================================

# ------------------------------------------------------------
# Mode 1: Console Email Backend
# ------------------------------------------------------------
# This is the default mode.
# It does NOT send real emails.
# Verification codes and password reset links will be printed
# in the backend container logs.
#
# View backend logs:
# docker compose logs -f backend
# ------------------------------------------------------------

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com


# ------------------------------------------------------------
# Mode 2: SMTP Email Backend
# ------------------------------------------------------------
# If you want to send real emails, comment out the console
# settings above and enable the SMTP settings below.
#
# IMPORTANT:
# EMAIL_HOST_PASSWORD must be an App Password generated by
# your email provider. It is NOT the original password used
# to log in to your email account.
#
# For example, if you use Gmail, you need to create a Google
# App Password and put that value in EMAIL_HOST_PASSWORD.
# ------------------------------------------------------------

# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DEFAULT_FROM_EMAIL=your-email@example.com
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-email-app-password
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True


# ============================================================
# Frontend Settings
# ============================================================

# Frontend base URL.
# This is used when generating password reset links.
# When using OOP_nginx as the system entry point, keep this value.
FRONTEND_BASE_URL=http://127.0.0.1:8088


# ============================================================
# AI Service Settings
# ============================================================

# Host path of the AI project folder.
# The default assumes that OOP-AI and project are at the same level:
#
# OOP_Final_Project/
# ├── project/
# ├── OOP_nginx/
# └── OOP-AI/
AI_PROJECT_HOST_PATH=../OOP-AI

# AI service URL inside Docker Compose network.
AI_SERVICE_URL=http://ai_service:9000

# Timeout in seconds when backend waits for AI service response.
AI_SERVICE_TIMEOUT=5

# AI project root path inside the AI service container.
AI_PROJECT_ROOT=/oop-ai

# AI model checkpoint path inside the AI service container.
AI_CHECKPOINT_PATH=/oop-ai/experiments/200k-rand-v1/checkpoint_dqn.pt

# AI execution device.
AI_DEVICE=cpu

# Python path required by the AI module.
PYTHONPATH=/oop-ai/vendor/rlcard